# AI Second Brain - Environment Variables
# Copy this to .env and fill in your values

# Anthropic API Key (get from https://console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Server Configuration
PORT=3001
HOST=localhost

# ChromaDB Configuration (runs locally by default)
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Security - random string to authenticate Chrome Extension requests
EXTENSION_SECRET=your_random_secret_here_change_this

# Optional: Max items to store (0 = unlimited)
MAX_STORAGE_ITEMS=0
